{
  "name": "@cyberpravda/backend",
  "version": "0.0.0",
  "private": true,
  "description": "CyberPravda backend (Fastify + Drizzle + PostgreSQL).",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@cyberpravda/shared-zod": "workspace:*",
    "fastify": "^5.2.0",
