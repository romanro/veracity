    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cyberpravda/eslint-config": "workspace:*",
    "@cyberpravda/tsconfig": "workspace:*",
    "@types/node": "^20.17.10",
    "eslint": "^9.17.0",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  }
}
